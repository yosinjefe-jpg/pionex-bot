# Pionex API Credentials Config
# Consigue tus llaves en: https://www.pionex.com/my-account/api
# Asegúrate de darles permisos de "Lectura" y "Operar" si deseas que el bot cree o modifique operaciones.

PIONEX_API_KEY=tu_api_key_aqui
PIONEX_API_SECRET=tu_secret_key_aqui

# Notion API Config (para reportes estratégicos cada 3 días)
# Crea una integración en: https://www.notion.so/my-integrations
# Comparte tu página de Notion de destino con esta integración
NOTION_TOKEN=tu_notion_token_aqui (comienza con secret_)
NOTION_PAGE_ID=tu_notion_page_id_aqui (el ID de 32 caracteres de la página madre)

# Telegram Config (para alertas y reportes de rendimiento cada 24 horas)
# Crea un bot hablando con @BotFather en Telegram
# Obtén tu ID de chat hablando con @userinfobot en Telegram
TELEGRAM_BOT_TOKEN=tu_telegram_bot_token_aqui
TELEGRAM_CHAT_ID=tu_telegram_chat_id_aqui
